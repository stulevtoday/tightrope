{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client", "vitest/globals"],
    "baseUrl": "."
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx", "vite.config.ts", "playwright.config.ts"]
}
