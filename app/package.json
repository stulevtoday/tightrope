{
  "name": "tightrope",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "build": {
    "appId": "com.tightrope.desktop",
    "compression": "maximum",
    "productName": "Tightrope",
    "icon": "src/renderer/assets/load_balancer.png",
    "files": [
      "**/*",
      "!**/*.map"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "native/tightrope-core.node",
        "to": "native/tightrope-core.node"
      }
    ],
    "mac": {
      "icon": "src/renderer/assets/load_balancer.png",
      "target": [
        "dir"
      ]
    },
    "win": {
      "icon": "src/renderer/assets/load_balancer.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "protocols": [
      {
        "name": "Tightrope Deep Link",
        "schemes": [
          "tightrope"
        ]
      }
    ]
  },
  "scripts": {
    "ensure:native": "npm run ensure:native:release",
    "ensure:native:release": "node ./scripts/native-module.js --mode=release",
    "ensure:native:debug": "node ./scripts/native-module.js --mode=debug",
    "predev": "npm run ensure:native:debug",
    "dev": "concurrently \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npm run ensure:native:debug && node ./scripts/start-electron-dev.js",
    "clean:dist": "node -e \"const fs=require('node:fs');fs.rmSync('dist/main',{recursive:true,force:true});fs.rmSync('dist/preload',{recursive:true,force:true});fs.rmSync('dist/renderer',{recursive:true,force:true});\"",
    "build:main": "tsc -p tsconfig.main.build.json",
    "build:renderer": "vite build",
    "bundle:prep": "npm run ensure:native:release && npm run stage:native && npm run clean:dist && npm run build:main && npm run build:renderer",
    "bundle:mac": "npm run bundle:prep && electron-builder --mac --publish never",
    "bundle:win": "npm run bundle:prep && electron-builder --win --publish never",
    "build": "npm run bundle:prep && electron-builder --publish never",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "check:window-tightrope": "node ./scripts/check-window-tightrope.js",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:ui": "playwright test",
    "test": "npm run check:window-tightrope && npm run test:unit && npm run test:ui",
    "build:native": "node ./scripts/native-module.js --force --mode=release",
    "stage:native": "node ./scripts/stage-native-module.js"
  },
  "dependencies": {
    "i18next": "^26.0.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.547.0",
    "node-addon-api": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.7"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.1",
    "cmake-js": "^7.0.0",
    "concurrently": "^9.1.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.2.7",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  }
}
